---
import { getCollection, render } from 'astro:content';
import ContentLayout from '@/layouts/ContentLayout.astro';
import { formatDate, readingTime, sortByDate } from '@/utils/content';

export async function getStaticPaths() {
  const posts = sortByDate((await getCollection('blog')).filter((post) => !post.data.draft));
  return posts.map((post, index) => ({
    params: { slug: post.slug },
    props: {
      post,
      previous: posts[index + 1],
      next: posts[index - 1]
    }
  }));
}

const { post, previous, next } = Astro.props;
const { Content, headings } = await render(post);
---

<ContentLayout title={post.data.title} description={post.data.description} eyebrow={`${formatDate(post.data.pubDate)} / ${readingTime(post.body)}`}>
  <Fragment slot="aside">
    <p class="font-mono text-xs uppercase tracking-[0.16em] text-[var(--accent)]">Contents</p>
    <ol class="mt-4 space-y-2">
      {headings.filter((heading) => heading.depth <= 3).map((heading) => (
        <li><a class="hover:text-[var(--text)]" href={`#${heading.slug}`}>{heading.text}</a></li>
      ))}
    </ol>
  </Fragment>
  <Content />
  <nav class="mt-12 grid gap-3 border-t border-[var(--line)] pt-6 sm:grid-cols-2">
    {previous && <a class="notebook-panel rounded-md p-4" href={`/blog/${previous.slug}/`}><span class="font-mono text-xs text-[var(--muted)]">Previous</span><br />{previous.data.title}</a>}
    {next && <a class="notebook-panel rounded-md p-4 sm:text-right" href={`/blog/${next.slug}/`}><span class="font-mono text-xs text-[var(--muted)]">Next</span><br />{next.data.title}</a>}
  </nav>
</ContentLayout>
