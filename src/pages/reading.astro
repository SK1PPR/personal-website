---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Card from '@/components/Card.astro';

const current = ['Designing Data-Intensive Applications', 'System Design Interview by Alex Xu'];
const completed = ['Computer Networking: A Top-Down Approach', 'Operating Systems: Three Easy Pieces'];
const notes = ['Distributed Systems', 'Operating Systems', 'Linux', 'Databases', 'Networking', 'Security', 'Performance Engineering'];
---

<BaseLayout title="Reading" description="Books and learning notes across distributed systems, operating systems, Linux, databases, networking, security, and performance engineering.">
  <section class="mx-auto max-w-page px-4 py-12 sm:px-6">
    <p class="mb-4 font-mono text-xs uppercase tracking-[0.18em] text-[var(--accent)]">Learning log</p>
    <h1 class="text-4xl font-semibold tracking-normal sm:text-5xl">Reading</h1>
    <div class="mt-10 grid gap-4 lg:grid-cols-3">
      <Card title="Currently Reading" meta="active">
        <ul class="mt-4 space-y-2 text-sm text-[var(--muted)]">{current.map((book) => <li>{book}</li>)}</ul>
      </Card>
      <Card title="Completed Books" meta="archive">
        <ul class="mt-4 space-y-2 text-sm text-[var(--muted)]">{completed.map((book) => <li>{book}</li>)}</ul>
      </Card>
      <Card title="Reading Notes" meta="topics">
        <div class="mt-4 flex flex-wrap gap-2">
          {notes.map((topic) => <span class="rounded border border-[var(--line)] px-2 py-1 font-mono text-xs text-[var(--muted)]">{topic}</span>)}
        </div>
      </Card>
    </div>
  </section>
</BaseLayout>
