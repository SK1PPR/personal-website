---
interface Props {
  href?: string;
  title: string;
  meta?: string;
  description?: string;
}

const { href, title, meta, description } = Astro.props;
const Tag = href ? 'a' : 'article';
---

<Tag href={href} class="notebook-panel block rounded-md p-5 transition hover:border-[var(--accent)]">
  {meta && <p class="mb-3 font-mono text-xs uppercase tracking-[0.16em] text-[var(--muted)]">{meta}</p>}
  <h3 class="text-lg font-semibold">{title}</h3>
  {description && <p class="mt-3 text-sm leading-6 text-[var(--muted)]">{description}</p>}
  <slot />
</Tag>
