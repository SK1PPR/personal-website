---
interface Props {
  title: string;
  eyebrow?: string;
  description?: string;
}

const { title, eyebrow, description } = Astro.props;
---

<section class="py-10">
  <div class="mb-6 max-w-3xl">
    {eyebrow && <p class="mb-2 font-mono text-xs uppercase tracking-[0.18em] text-[var(--accent)]">{eyebrow}</p>}
    <h2 class="text-2xl font-semibold tracking-normal sm:text-3xl">{title}</h2>
    {description && <p class="mt-3 text-[var(--muted)]">{description}</p>}
  </div>
  <slot />
</section>
