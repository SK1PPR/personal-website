---
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { SITE } from '@/consts';
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  pubDate?: Date;
  updatedDate?: Date;
  tags?: string[];
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = SITE.title,
  description = SITE.description,
  image = '/og.svg',
  type = 'website',
  pubDate,
  updatedDate,
  tags = [],
  jsonLd = []
} = Astro.props;

const canonical = new URL(Astro.url.pathname, SITE.url);
const pageTitle = title === SITE.title ? title : `${title} - ${SITE.name}`;
const siteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.name,
  url: SITE.url,
  description: SITE.description,
  publisher: {
    '@type': 'Person',
    name: SITE.author
  }
};
const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: SITE.author,
  url: SITE.url,
  email: SITE.email,
  telephone: SITE.phone,
  address: {
    '@type': 'PostalAddress',
    addressLocality: SITE.location
  },
  sameAs: [SITE.github, SITE.gitlab, SITE.linkedin, SITE.twitter],
  jobTitle: 'Data Infrastructure and Distributed Systems Engineer',
  alumniOf: {
    '@type': 'CollegeOrUniversity',
    name: 'Indian Institute of Technology Roorkee'
  },
  knowsAbout: [
    'Distributed systems',
    'Data infrastructure',
    'Databases',
    'Rust',
    'Linux',
    'Performance engineering',
    'Observability'
  ]
};
const pageJsonLd = Array.isArray(jsonLd) ? jsonLd : [jsonLd];
const jsonLdGraph = [siteJsonLd, personJsonLd, ...pageJsonLd].filter(Boolean);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title={`${SITE.name} RSS`} href="/rss.xml" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(image, SITE.url)} />
    <meta property="og:image:alt" content={`${SITE.name} engineering notebook`} />
    {type === 'article' && pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
    {type === 'article' && (updatedDate || pubDate) && <meta property="article:modified_time" content={(updatedDate || pubDate)?.toISOString()} />}
    {type === 'article' && <meta property="article:author" content={SITE.author} />}
    {type === 'article' && tags.map((tag) => <meta property="article:tag" content={tag} />)}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:creator" content="@khushalSkippr" />
    <meta name="theme-color" content="#0d0e0b" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdGraph)} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
